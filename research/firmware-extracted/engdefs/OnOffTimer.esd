    slider
        value           per 0 0x0002059d 0 60
        label           "Transport delay (Sec)"
        poll            0
   choice
        value           per 0 0x0002044b
        label           "Power down timer state"
   button
      value             per 1 0x00050037 ""
      label             "reset all timer values"
  button
      value             per 1 0x00050041 ""
      label             "reset all timers to test"
