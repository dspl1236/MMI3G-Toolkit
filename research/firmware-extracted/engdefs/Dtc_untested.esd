#############################################
#
#	Engineering screeen definition
#  for displaying DTCs
#  by M. Wolf
#
#############################################


#######################################################
#
# DTC menu displaying all untested DTCs
#
#######################################################
screen	untested_DTCs	DTC

   table
   content        per 2 0x00010004
   label          "untested DTCs"
    poll          30000
	maxrows        10
	orientation   horizontal 
	columns ( "intern" int 70 ) ( "extern" String 120 ) ( "status" String 80 ) ( "!T" String 20 ) ( "S" String 20 ) ( "A" String 20 ) ( "L" String 20 ) ( "name" String 300 )
